EMFONT_ENV=staging
EMFONT_SERVICE_NAME=emfont-controller
EMFONT_VERSION=0.1.0
EMFONT_API_VERSION=v1
EMFONT_SHUTDOWN_TIMEOUT=30s
EMFONT_SHUTDOWN_PROPAGATION_DELAY=5s

EMFONT_LOG_LEVEL=info
EMFONT_LOG_FORMAT=text

EMFONT_HTTP_ADDR=:8080
EMFONT_BACKEND_BASE_URL=https://localhost:8080
EMFONT_HTTP_REQUEST_TIMEOUT=15s
EMFONT_HTTP_READ_HEADER_TIMEOUT=5s
EMFONT_HTTP_READ_TIMEOUT=5s
EMFONT_HTTP_WRITE_TIMEOUT=20s
EMFONT_HTTP_IDLE_TIMEOUT=120s
EMFONT_HTTP_MAX_HEADER_BYTES=65536
# Controller startup accepts only staging or production and requires explicit origins.
EMFONT_CORS_ALLOWED_ORIGINS=https://localhost:3000

EMFONT_RATE_LIMIT_ENABLED=true
EMFONT_RATE_LIMIT_REQUESTS_PER_SECOND=20
EMFONT_RATE_LIMIT_BURST=40
EMFONT_GLOBAL_RATE_LIMIT_REQUESTS_PER_SECOND=200
EMFONT_GLOBAL_RATE_LIMIT_BURST=400
EMFONT_RATE_LIMIT_MAX_CLIENTS=10000
EMFONT_RATE_LIMIT_IDLE_TIMEOUT=10m
# Enable only when clients cannot bypass a trusted proxy that replaces X-Forwarded-For.
EMFONT_TRUST_PROXY_HEADERS=false
# Required when proxy-header trust is enabled; list only immediate proxy peer CIDRs.
# Every /0 prefix is rejected, including 0.0.0.0/0 and ::/0.
EMFONT_TRUSTED_PROXY_CIDRS=

EMFONT_DATABASE_URL=
EMFONT_DATABASE_MAX_OPEN_CONNS=10
EMFONT_DATABASE_MIN_IDLE_CONNS=0
EMFONT_DATABASE_CONN_MAX_LIFETIME=30m

EMFONT_MINIO_ENABLED=false
EMFONT_MINIO_ENDPOINT=localhost:9000
EMFONT_MINIO_ACCESS_KEY=
EMFONT_MINIO_SECRET_KEY=
EMFONT_MINIO_SESSION_TOKEN=
EMFONT_MINIO_BUCKET=emfont
EMFONT_MINIO_REGION=
EMFONT_MINIO_SECURE=false
EMFONT_MINIO_BACKFILL_CONCURRENCY=4
EMFONT_MINIO_PUBLIC_BASE_URL=https://localhost:9000/emfont
EMFONT_MINIO_PRESIGN_EXPIRY=1h

EMFONT_FORCE_MIN=false
EMFONT_FONT_BUILDER_VERSION=harfbuzz-woff2-v1
EMFONT_FONT_BUILD_LEASE=2m
EMFONT_FONT_BUILD_TIMEOUT=90s
EMFONT_FONT_BUILD_CONCURRENCY=2
EMFONT_FONT_MAX_PENDING_BUILDS=16
EMFONT_FONT_MAX_ARTIFACTS=100000
EMFONT_FONT_MAX_ACCOUNTED_BYTES=53687091200
EMFONT_FONT_MAX_TERMINAL_FAILURES=10000
EMFONT_FONT_MAX_SOURCE_BYTES=134217728
EMFONT_FONT_WORKER_PATH=emfont-fontworker
EMFONT_FONT_WORKER_MAX_OUTPUT_BYTES=134217728
EMFONT_FONT_WORKER_ADDRESS_SPACE_BYTES=2147483648
EMFONT_FONT_WORKER_CPU_SECONDS=60
EMFONT_FONT_WORKER_FILE_SIZE_BYTES=134217728
EMFONT_FONT_WORKER_OPEN_FILES=32
EMFONT_FONT_WORKER_STDERR_BYTES=16384
EMFONT_FONT_ARTIFACT_TOUCH_INTERVAL=5m

EMFONT_CLEANUP_ARTIFACT_RETENTION=720h
EMFONT_CLEANUP_RETIREMENT_GRACE=2h
EMFONT_CLEANUP_ORPHAN_GRACE=6h
EMFONT_CLEANUP_TIMEOUT=30m
EMFONT_CLEANUP_DATABASE_BATCH_SIZE=100
EMFONT_CLEANUP_MAX_DATABASE_ROWS=10000
EMFONT_CLEANUP_OBJECT_PAGE_SIZE=500
EMFONT_CLEANUP_MAX_OBJECT_PAGES=10000

EMFONT_METRICS_ENABLED=false
EMFONT_METRICS_PATH=/metrics
# Required in every environment when metrics are enabled.
EMFONT_METRICS_BEARER_TOKEN=

EMFONT_TRACING_ENABLED=false
EMFONT_OTEL_EXPORTER_OTLP_ENDPOINT=
EMFONT_TRACING_SAMPLE_RATIO=1
